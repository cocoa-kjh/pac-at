+      <SequenceEditor value={items} onChange={setItems} scenes={scenes} />
+      <button onClick={create}>스케쥴 생성</button>
+      <ul>{schedules.map(s => (
+        <li key={s.id}>#{s.id} {s.start_at} — {s.status}
+          <button onClick={() => api.deleteSchedule(s.id).then(reload)}>취소</button>
+        </li>))}</ul>
+    </div>);
